    {
      "name": "1. Login / Registro de Usuario",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    pm.globals.set(\"usuario_id\", jsonData.id);",
              "    console.log(\"ID de usuario guardado en globales: \", jsonData.id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"LeonardoSolis\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/users/login",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "users",
            "login"
          ]
        },
        "description": "Inicia sesión o registra al usuario de forma automática por su nombre de usuario. Guarda el ID resultante en las variables globales de Postman."
      },
      "response": []
    },
    {
      "name": "2. Obtener Catálogo de Hitos",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/hitos?usuarioId={{usuario_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "hitos"
          ],
          "query": [
            {
              "key": "usuarioId",
              "value": "{{usuario_id}}",
              "description": "ID del usuario para verificar qué hitos han sido visitados (bloqueo lógico)."
            }
          ]
        },
        "description": "Retorna el catálogo completo con los 50 hitos históricos. Si el hito no ha sido visitado por el usuario, su historia completa e imagenUrl se devuelven bloqueadas."
      },
      "response": []
    },
